{
  "name": "backend",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "start": "node dist/server.js",
    "dev": "nodemon --exec ts-node src/server.ts",
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "cd e2e && playwright test",
    "test:e2e:headed": "cd e2e && playwright test --headed",
    "test:e2e:debug": "cd e2e && playwright test --debug",
    "test:e2e:ui": "cd e2e && playwright test --ui",
    "test:e2e:setup": "cd e2e && playwright test tests/setup.spec.ts",
    "test:e2e:auth": "cd e2e && playwright test tests/auth.spec.ts",
    "test:e2e:workout": "cd e2e && playwright test tests/workout.spec.ts",
    "test:e2e:offline": "cd e2e && playwright test tests/offline-sync.spec.ts",
    "test:all": "pnpm test && pnpm test:e2e",
    "e2e:install": "cd e2e && playwright install",
    "e2e:report": "cd e2e && playwright show-report",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.1.0",
    "@fastify/helmet": "^13.0.1",
    "@fastify/rate-limit": "^10.3.0",
    "@prisma/client": "^6.17.0",
    "@react-native-community/netinfo": "^11.4.1",
    "@types/bcryptjs": "^3.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/pg": "^8.15.6",
    "bcryptjs": "^3.0.2",
    "fastify": "^5.6.1",
    "joi": "^18.0.1",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.16.3",
    "prisma": "^6.17.0",
    "react-native-sqlite-storage": "^6.0.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@types/node": "^24.5.2",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^8.44.1",
    "@typescript-eslint/parser": "^8.44.1",
    "eslint": "^9.36.0",
    "nodemon": "^3.1.10",
    "playwright": "^1.57.0",
    "supertest": "^7.1.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2",
    "vitest": "^4.0.15"
  },
  "packageManager": "pnpm@11.1.0+sha512.0c44e842e5686b2c061a81adda8b2258bd8818e9704b2cf2c63d56b931a7b2e910092e085027003b96ca3911ab56a07f6df5abaed2be9925034cdd686a535b14",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "esbuild",
      "prisma"
    ]
  }
}
