# Environment variables template
# Copy this file to .env and fill in your actual values

# Database configuration
DATABASE_URL="DATABASE_URL"

# Server configuration (optional)
# PORT=3000
# NODE_ENV=development

# JWT Secret (if you add authentication later)
# JWT_SECRET="your-super-secret-jwt-key"

# CORS settings (optional, separate by comma).
# Em dev, localhost/127.0.0.1 e IPs privados (10.x, 192.168.x, 172.16-31.x) são liberados automaticamente.
# Em produção, defina explicitamente os origins permitidos do frontend.
# ALLOWED_ORIGINS="https://pr-tracker.vercel.app"

# Cookie signing secret (use a long random value in production)
# COOKIE_SECRET="change-me-to-a-long-random-string"
