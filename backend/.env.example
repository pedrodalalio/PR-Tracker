# =============================================================================
# PR-Tracker Backend — Variáveis de ambiente
# =============================================================================
# Copia este arquivo pra `.env` e preenche os valores. Tudo aqui é lido pelo
# backend em runtime (src/server.ts, src/lib/auth.ts, src/lib/cookies.ts).

# -----------------------------------------------------------------------------
# OBRIGATÓRIAS
# -----------------------------------------------------------------------------

# Conexão com o PostgreSQL. Em produção, usar a string do Neon (ou outro provedor).
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# Secret usado pra assinar/verificar JWTs. Em produção PRECISA ser um valor
# longo e aleatório. Gere com: openssl rand -hex 64
JWT_SECRET="dev-only-change-in-production"

# Secret usado pelo @fastify/cookie pra assinar cookies (não criptografa).
# Em produção, gere com: openssl rand -hex 32
COOKIE_SECRET="dev-only-change-in-production"

# -----------------------------------------------------------------------------
# AMBIENTE / CORS
# -----------------------------------------------------------------------------

# `production` ativa: cookies com SameSite=None+Secure (necessário pra
# frontend cross-origin) e CORS estrito (sem fallback de localhost/IPs privados).
# Use `development` (ou deixe vazio) localmente.
NODE_ENV=development

# Origins permitidos no CORS, separados por vírgula. SEM barra final.
# Em dev, localhost/127.0.0.1 e IPs privados são liberados automaticamente —
# essa lista é additive sobre eles.
# Em produção, é a única fonte de truth — coloca a URL exata do frontend.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173

# -----------------------------------------------------------------------------
# STRAVA (opcional — habilita integração de import direto)
# -----------------------------------------------------------------------------

# Crie um app em https://www.strava.com/settings/api e cole aqui:
# STRAVA_CLIENT_ID=12345
# STRAVA_CLIENT_SECRET=abcdef0123456789

# URL do callback que o backend expõe. Tem que bater com o "Authorization
# Callback Domain" do app do Strava (só o domínio é checado, não a porta/path).
# STRAVA_REDIRECT_URI=http://localhost:3000/strava/callback

# URL do frontend pra onde o callback redireciona após sucesso/erro.
# FRONTEND_URL=http://localhost:5173

# -----------------------------------------------------------------------------
# OPCIONAL
# -----------------------------------------------------------------------------

# Porta de escuta. Padrão 3000.
# PORT=3000
