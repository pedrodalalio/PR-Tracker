// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  email     String   @unique
  password  String   // bcrypt hash
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  workouts            Workout[]
  userGoals           UserGoals?
  refreshTokens       RefreshToken[]
  weightEntries       WeightEntry[]
  weeklyGoalHistory   WeeklyGoalEntry[]
  runs                Run[]
  stravaConnection    StravaConnection?
  passwordResetTokens PasswordResetToken[]
  workoutTemplates    WorkoutTemplate[]

  @@map("users")
}

model StravaConnection {
  id           String   @id @default(uuid())
  userId       String   @unique
  athleteId    BigInt   // Strava athlete ID (numérico, vem como número grande)
  accessToken  String
  refreshToken String
  expiresAt    DateTime // quando o accessToken vence
  scope        String   // espaço-separado, ex: "read,activity:read_all"
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("strava_connections")
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  isRevoked Boolean  @default(false)
  createdAt DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRevoked])
  @@map("refresh_tokens")
}

model Exercise {
  id          String   @id @default(uuid())
  name        String   @unique
  category    Category
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  workoutExercises         WorkoutExercise[]
  muscleGroups             ExerciseMuscleGroup[]
  workoutTemplateExercises WorkoutTemplateExercise[]

  @@map("exercises")
}

model ExerciseMuscleGroup {
  id         String   @id @default(uuid())
  exerciseId String
  muscleGroup String

  // Relations
  exercise   Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  @@unique([exerciseId, muscleGroup])
  @@map("exercise_muscle_groups")
}

model Workout {
  id          String      @id @default(uuid())
  userId      String
  name        String
  date        DateTime
  workoutType WorkoutType
  dayOfWeek   WeekDay
  startTime   DateTime?
  endTime     DateTime?
  notes       String?
  templateId  String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  // Relations
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercises WorkoutExercise[]
  template  WorkoutTemplate?  @relation(fields: [templateId], references: [id], onDelete: SetNull)

  @@index([userId, date])
  @@index([userId, templateId, date])
  @@map("workouts")
}

model WorkoutExercise {
  id         String  @id @default(uuid())
  exerciseId String
  workoutId  String
  notes      String?

  // Relations
  exercise Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  workout  Workout  @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  sets     Set[]

  @@map("workout_exercises")
}

model Set {
  id               String  @id @default(uuid())
  workoutExerciseId String
  reps             Int
  weight           Float
  duration         Int?    // for cardio exercises (in seconds)
  distance         Float?  // for runs (in meters)
  pace             Float?  // calculated pace (minutes per kilometer)

  // Relations
  workoutExercise WorkoutExercise @relation(fields: [workoutExerciseId], references: [id], onDelete: Cascade)

  @@map("sets")
}

model WorkoutTemplate {
  id          String      @id @default(uuid())
  userId      String
  name        String
  workoutType WorkoutType
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  // Relations
  user      User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercises WorkoutTemplateExercise[]
  workouts  Workout[]

  @@index([userId])
  @@map("workout_templates")
}

model WorkoutTemplateExercise {
  id         String  @id @default(uuid())
  templateId String
  exerciseId String
  position   Int
  notes      String?

  // Relations
  template WorkoutTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  exercise Exercise        @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  @@index([templateId, position])
  @@map("workout_template_exercises")
}

model UserGoals {
  id                   String   @id @default(uuid())
  userId               String   @unique
  weeklyWorkoutGoal    Int      @default(3)
  // Dias da semana que o usuário pretende treinar (subset dos valores de WeekDay).
  // Vazio = sem dias planejados específicos (só conta a meta semanal).
  targetDays          String[] @default([])
  currentStreak        Int      @default(0)
  bestStreak          Int      @default(0)
  totalWeeksCompleted Int      @default(0)
  lastWorkoutDate     DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_goals")
}

model WeeklyGoalEntry {
  id                String   @id @default(uuid())
  userId            String
  weeklyWorkoutGoal Int
  effectiveFrom     DateTime
  createdAt         DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, effectiveFrom])
  @@map("weekly_goal_history")
}

model Run {
  id            String    @id @default(uuid())
  userId        String
  name          String?
  date          DateTime
  startTime     DateTime?
  endTime       DateTime?
  distance      Float     // metros
  duration      Int       // segundos (elapsed: tempo total da sessão)
  movingTime    Int?      // segundos (excluindo paradas; ~o que o Strava chama de "moving time")
  pace          Float?    // segundos por km (baseado em movingTime quando disponível)
  elevationGain Float?    // metros
  notes         String?
  source        String    @default("manual") // manual, gpx, strava
  externalId    String?
  routePoints   Json?     // [{ lat, lng, ele?, t? }]
  splits        Json?     // [{ km, duration, pace }]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  // Evita duplicar atividade do Strava (mesma pessoa importando 2x).
  // NULLs são permitidos múltiplas vezes em UNIQUE no Postgres, então
  // runs manuais/GPX sem externalId não são afetados.
  @@unique([userId, source, externalId])
  @@map("runs")
}

model WeightEntry {
  id         String   @id @default(uuid())
  userId     String
  weight     Float
  recordedAt DateTime
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, recordedAt])
  @@map("weight_entries")
}

enum Category {
  Upper
  Lower
  Cardio
}

enum WorkoutType {
  upper
  lower
  cardio
}

enum WeekDay {
  segunda
  terça
  quarta
  quinta
  sexta
  sabado
  domingo
}
