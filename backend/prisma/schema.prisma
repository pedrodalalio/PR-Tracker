// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Exercise {
  id          String   @id @default(uuid())
  name        String   @unique
  category    Category
  muscleGroups String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  workoutExercises WorkoutExercise[]

  @@map("exercises")
}

model Workout {
  id          String      @id @default(uuid())
  name        String
  date        DateTime
  workoutType WorkoutType
  dayOfWeek   WeekDay
  startTime   DateTime?
  endTime     DateTime?
  notes       String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  // Relations
  exercises WorkoutExercise[]

  @@map("workouts")
}

model WorkoutExercise {
  id         String  @id @default(uuid())
  exerciseId String
  workoutId  String
  notes      String?

  // Relations
  exercise Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  workout  Workout  @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  sets     Set[]

  @@map("workout_exercises")
}

model Set {
  id               String  @id @default(uuid())
  workoutExerciseId String
  reps             Int
  weight           Float
  duration         Int?    // for cardio exercises (in seconds)
  distance         Float?  // for runs (in meters)
  pace             Float?  // calculated pace (minutes per kilometer)

  // Relations
  workoutExercise WorkoutExercise @relation(fields: [workoutExerciseId], references: [id], onDelete: Cascade)

  @@map("sets")
}

model UserGoals {
  id                   String   @id @default(uuid())
  weeklyWorkoutGoal    Int      @default(3)
  currentStreak        Int      @default(0)
  bestStreak          Int      @default(0)
  totalWeeksCompleted Int      @default(0)
  lastWorkoutDate     DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@map("user_goals")
}

enum Category {
  Upper
  Lower
  Cardio
}

enum WorkoutType {
  upper
  legs
  cardio
}

enum WeekDay {
  monday
  tuesday
  wednesday
  thursday
  friday
  saturday
  sunday
}
